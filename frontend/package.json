{
  "name": "anamneo-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-watch.js --webpack",
    "dev:turbo": "node scripts/dev-watch.js",
    "build": "node ./scripts/next-build.js",
    "start": "next start -H 0.0.0.0 -p 5555",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "test": "jest",
    "test:watch": "jest --watch --maxWorkers=2",
    "test:e2e": "playwright test",
    "test:e2e:workflow-clinical": "playwright test --workers=1 tests/e2e/workflow-clinical.spec.ts",
    "test:e2e:workflow-clinical:repeat": "sh -c 'for run in 1 2 3; do echo \"[workflow-clinical repeat $run/3]\"; playwright test --workers=1 tests/e2e/workflow-clinical.spec.ts || exit $?; done'",
    "test:e2e:smoke": "playwright test --workers=1 tests/e2e/smoke.spec.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@react-pdf/renderer": "^3.1.14",
    "@sentry/nextjs": "^10.46.0",
    "@tanstack/react-query": "^5.17.9",
    "axios": "^1.15.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.2.0",
    "jwt-decode": "^4.0.0",
    "next": "^16.2.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.3",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.0.1",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.17",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "follow-redirects": "1.16.0",
    "glob@13.0.6": {
      "brace-expansion": "^5.0.5"
    }
  }
}
