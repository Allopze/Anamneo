# ============================================================
# Configuracion local del frontend
# Copiar a .env si vas a ejecutar Next.js por separado.
# ============================================================

# ------------------------------------------------------------
# ENTORNO
# ------------------------------------------------------------
NODE_ENV=development

# ------------------------------------------------------------
# FRONTEND / NEXT
# ------------------------------------------------------------
# URL publica del frontend usada por pantallas y enlaces.
APP_PUBLIC_URL=http://localhost:5555

# URL de API consumida por el navegador.
# Mantener en same-origin para preservar cookies HttpOnly.
NEXT_PUBLIC_API_URL=/api

# Fuerza modo compartido en navegadores del frontend.
NEXT_PUBLIC_FORCE_SHARED_DEVICE_MODE=false

# Origenes extra permitidos por Next.js en desarrollo.
NEXT_ALLOWED_DEV_ORIGINS=

# Destino real del proxy server-side de Next.js.
API_PROXY_TARGET=http://localhost:5678/api

# ------------------------------------------------------------
# OBSERVABILIDAD
# ------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
