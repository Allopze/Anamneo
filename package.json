{
  "name": "anamneo",
  "version": "1.0.0",
  "description": "Sistema de gestión de fichas clínicas",
  "private": true,
  "scripts": {
    "dev": "bash ./scripts/dev-supervisor.sh",
    "dev:backend": "npm --prefix backend run start:dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "install:all": "npm install && npm --prefix backend install && npm --prefix frontend install",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "npm --prefix backend run build",
    "build:frontend": "npm --prefix frontend run build",
    "db:migrate": "npm --prefix backend run prisma:migrate",
    "db:seed": "npm --prefix backend run prisma:seed",
    "db:reset": "npm --prefix backend run db:reset",
    "db:backup": "npm --prefix backend run db:sqlite:backup",
    "db:restore:drill": "npm --prefix backend run db:sqlite:restore:drill",
    "db:monitor": "npm --prefix backend run db:sqlite:monitor",
    "db:ops": "npm --prefix backend run db:sqlite:ops",
    "db:ops:monitor": "npm --prefix backend run db:sqlite:ops:monitor",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "release": "bash scripts/release.sh",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org alejandro-lopez-zelaya --project node-nestjs .next && sentry-cli sourcemaps upload --org alejandro-lopez-zelaya --project node-nestjs .next"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@sentry/cli": "^2.58.5"
  }
}