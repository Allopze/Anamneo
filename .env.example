# ============================================================
# Ejemplo de configuración del proyecto
# Copia este archivo a .env y cambia solo lo que necesites.
# Los comentarios explican para qué sirve cada ajuste en lenguaje simple.
# ============================================================

# ------------------------------------------------------------
# ENTORNO
# ------------------------------------------------------------
# Le dice a la app si estás en tu computador, en pruebas o en un servidor real.
# Normalmente no necesitas cambiarlo.
NODE_ENV=development

# Alcance de despliegue soportado.
# La beta productiva actual es single-clinic: una clínica por instancia,
# base PostgreSQL y volúmenes aislados. Multi-tenant requiere un modelo Clinic/Tenant.
ANAMNEO_DEPLOYMENT_SCOPE=single-clinic

# ------------------------------------------------------------
# DATOS GUARDADOS
# ------------------------------------------------------------
# Aquí se define dónde se guarda la información de la app.
# Runtime usa el rol app con permisos DML; migraciones usan el rol owner.
DATABASE_URL="postgresql://anamneo_app:anamneo_app@localhost:5432/anamneo?schema=public&connection_limit=10&pool_timeout=10"
MIGRATION_DATABASE_URL="postgresql://anamneo_owner:anamneo_owner@localhost:5432/anamneo?schema=public"

# Credenciales usadas por Docker Compose para inicializar PostgreSQL.
# Cambialas en produccion. Genera valores aleatorios con:
#   openssl rand -base64 24
POSTGRES_DB=anamneo
POSTGRES_USER=anamneo_owner
POSTGRES_PASSWORD=anamneo_owner
ANAMNEO_APP_DB_PASSWORD=anamneo_app
# En produccion reemplaza por un valor aleatorio. El rol monitor tiene solo SELECT.
ANAMNEO_MONITOR_DB_PASSWORD=anamneo_monitor

# Base opcional para pruebas automáticas.
# Debe apuntar a PostgreSQL. Las suites crean/limpian bases aisladas cuando corresponde.
TEST_DATABASE_URL="postgresql://anamneo_owner:anamneo_owner@localhost:5432/anamneo_test?schema=public"
PLAYWRIGHT_DATABASE_URL="postgresql://anamneo_owner:anamneo_owner@localhost:5432/anamneo_playwright?schema=public"

# ------------------------------------------------------------
# ACCESO Y SEGURIDAD
# ------------------------------------------------------------
# Estas claves protegen el inicio de sesión.
# Deben ser largas, únicas y no compartirse con nadie.
#
# Comandos útiles para generar claves seguras:
#   openssl rand -base64 48
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=replace-with-a-secure-random-secret

# Tiempo durante el cual la sesión sigue siendo válida.
# Ejemplos: 15m, 30m, 1h, 12h
JWT_EXPIRES_IN=15m

# Segunda clave de seguridad para renovar la sesión.
# Debe ser distinta de JWT_SECRET.
JWT_REFRESH_SECRET=replace-with-a-different-secure-random-secret

# Clave para crear el primer usuario administrador.
# Solo se usa una vez al iniciar la app por primera vez.
# Ejemplos:
#   openssl rand -base64 48
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
BOOTSTRAP_TOKEN=replace-with-a-secure-bootstrap-token

# Tiempo máximo antes de pedir un inicio de sesión nuevo.
# Ejemplos: 7d, 14d, 30d
JWT_REFRESH_EXPIRES_IN=7d

# ------------------------------------------------------------
# OPERACIÓN DE BASE DE DATOS
# ------------------------------------------------------------
# Ajustes de respaldo, recuperación y monitoreo PostgreSQL.
# Si la dejas vacía, se usa una carpeta predeterminada.
PG_BACKUP_DIR=./backend/prisma/backups

# Cuántos días conservar los respaldos automáticos.
PG_BACKUP_RETENTION_DAYS=14

# Cuántas horas pueden pasar antes de considerar viejo el último respaldo.
PG_BACKUP_MAX_AGE_HOURS=24

# Cada cuántos días conviene probar una restauración de respaldo.
PG_RESTORE_DRILL_FREQUENCY_DAYS=7

# Copia off-machine (resiliencia ante fallo de disco). Vacía PG_BACKUP_MIRROR_DIR = desactivada.
# CAMBIA PG_BACKUP_MIRROR_HOST_DIR a un disco externo o carpeta sincronizada a nube (Drive/Dropbox);
# por defecto apunta al mismo disco (placeholder, no protege ante fallo de disco).
# IMPORTANTE: guarda ENCRYPTION_KEY y SETTINGS_ENCRYPTION_KEY aparte (un gestor de contraseñas);
# sin ellas los respaldos quedan indescifrables.
PG_BACKUP_MIRROR_HOST_DIR=./runtime/data/backups-mirror
PG_BACKUP_MIRROR_DIR=/app/data/backups-mirror
PG_BACKUP_MIRROR_RETENTION_DAYS=14

# Fuerza una prueba de restauración en la próxima ejecución.
# Déjalo en false salvo que quieras comprobar un respaldo a mano.
PG_FORCE_RESTORE_DRILL=false

# Horario para copias automáticas cuando usas Docker.
# Ejemplos: "0 */6 * * *" (cada 6h), "0 2 * * *" (2am diario), "*/30 * * * *" (cada 30min)
BACKUP_CRON_SCHEDULE=0 */6 * * *

# Cuándo mandar avisos del sistema de backups.
# Valores: on-failure | always | never
PG_NOTIFY_POLICY=on-failure

# Nombre que aparece en alertas y registros.
PG_ALERT_SERVICE_NAME=anamneo-backend

# Dirección a la que se envían avisos automáticos.
# Úsala si quieres recibir alertas por fallos de respaldo o espacio.
# Ejemplos:
#   Discord: https://discord.com/api/webhooks/XXXX/YYYY
#   Slack:   https://hooks.slack.com/services/XXXX/YYYY/ZZZZ
#   Ntfy:    https://ntfy.sh/anamneo-alerts
# Déjalo vacío si no quieres notificaciones.
PG_ALERT_WEBHOOK_URL=

# ------------------------------------------------------------
# BACKEND HTTP
# ------------------------------------------------------------
# Puerto donde responde la API.
PORT=5678

# Puertos visibles desde tu computador cuando usas Docker.
BACKEND_PORT=5678
FRONTEND_PORT=5555

# Dirección donde escucha cada servicio en tu computadora.
# El valor recomendado es 127.0.0.1 para no abrirlos a toda la red.
BACKEND_BIND_HOST=127.0.0.1
FRONTEND_BIND_HOST=127.0.0.1

# Zona horaria que usa la app para fechas importantes.
# Para la mayoría de los casos en Chile, deja America/Santiago.
APP_TIME_ZONE=America/Santiago

# Dirección autorizada para que el navegador hable con la API.
# Si cambias el frontend de lugar, probablemente también debas cambiar esto.
CORS_ORIGIN=http://localhost:5555,https://anamneo.cloudbox.lat

# Indica si la app está detrás de un proxy/reverse-proxy.
# - En desarrollo local: TRUST_PROXY=false
# - En produccion detras de cloudflared o nginx: TRUST_PROXY=1
# (la app exige un valor != "false" en NODE_ENV=production)
TRUST_PROXY=false

# ------------------------------------------------------------
# FRONTEND
# ------------------------------------------------------------
# Dirección pública del sitio. Se usa para enlaces y correos.
# En local suele ser http://localhost:5555.
APP_PUBLIC_URL=http://localhost:5555

# Dirección alternativa para el frontend. Si no la usas, déjala vacía.
FRONTEND_PUBLIC_URL=

# Dirección que usa el navegador para hablar con la API.
# En la mayoría de los casos debe quedarse en /api.
NEXT_PUBLIC_API_URL=/api

# Modo para computadores compartidos.
# Desactiva guardados locales pensados para uso personal.
NEXT_PUBLIC_FORCE_SHARED_DEVICE_MODE=true

# Dirección interna que usa Next.js para reenviar a la API.
# Normalmente apunta al backend local.
API_PROXY_TARGET=http://localhost:5678/api

# Otras direcciones desde donde puedes abrir la app en desarrollo.
# Si no necesitas compartirla en otra red, déjalo vacío.
NEXT_ALLOWED_DEV_ORIGINS=

# Content Security Policy estricta para el frontend (recomendado en produccion).
# Activa script-src con nonce y strict-dynamic en lugar de 'unsafe-inline'.
# Verifica en staging antes de activar: Next.js puede inyectar scripts inline en
# algunos escenarios. En desarrollo se ignora (siempre se usa unsafe-eval).
# Valores: true | false (default: false)
NEXT_PUBLIC_STRICT_CSP=false

# ------------------------------------------------------------
# CORREO SMTP (OPCIONAL)
# ------------------------------------------------------------
# Ajustes de correo. Solo necesitas completarlos si vas a enviar emails.
# Si ya los configuras desde la app, puedes dejar varios vacíos.
SETTINGS_ENCRYPTION_KEY=replace-with-a-secure-settings-key
SETTINGS_ENCRYPTION_KEYS=

# Clave de cifrado aplicacional para identificatorios de pacientes,
# secciones de encuentros y PHI. OBLIGATORIA en todos los entornos.
# Debe ser un string hex de 64 caracteres (256 bits).
#
# Generala con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Si rotas esta clave, los datos previos quedan ilegibles. Para rotacion
# segura ver docs/settings-key-rotation-runbook.md (mismo patron aplica).
ENCRYPTION_KEY=

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Anamneo
INVITATION_EMAIL_SUBJECT=Invitacion a {{clinicName}}

# ------------------------------------------------------------
# ARCHIVOS / UPLOADS
# ------------------------------------------------------------
# Tamaño máximo permitido para cada archivo subido.
# 10485760 equivale a 10 MB.
UPLOAD_MAX_SIZE=10485760

# Carpeta donde se guardan los archivos adjuntos.
# Si no la cambias, se usa la carpeta por defecto del proyecto.
UPLOAD_DEST=./uploads

# ------------------------------------------------------------
# CIFRADO EN EL DISCO
# ------------------------------------------------------------
# Indica si el disco del servidor ya está cifrado.
# La app lo usa como confirmación de seguridad antes de arrancar en producción.
ENCRYPTION_AT_REST_CONFIRMED=false

# ------------------------------------------------------------
# MONITOREO / APM (OPCIONAL)
# ------------------------------------------------------------
# Sentry ayuda a registrar errores de la app.
# Si no usas monitoreo, déjalo vacío.
SENTRY_DSN=
# Versión pública de Sentry para el frontend.
NEXT_PUBLIC_SENTRY_DSN=
# Habilita replay solo fuera de producción cuando quieras depurar.
NEXT_PUBLIC_SENTRY_REPLAY_ENABLED=false

# Token para que Prometheus consulte /api/metrics.
# Recomendado si levantas el stack de observabilidad.
# Genera uno con:
#   openssl rand -base64 48
METRICS_SCRAPE_TOKEN=

# Grafana local del stack de observabilidad.
# GRAFANA_ADMIN_PASSWORD es obligatorio en produccion. Genera uno con:
#   openssl rand -base64 24
# El fallback en docker-compose es "change-me-before-production" y NO debe usarse en produccion.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
PROMETHEUS_RETENTION=30d
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_PORT=3100
