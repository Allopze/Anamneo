# ============================================================
# Ejemplo de configuracion del proyecto
# Copiar a .env y ajustar segun el ambiente.
# Este archivo documenta que hace cada variable.
# ============================================================

# ------------------------------------------------------------
# ENTORNO
# ------------------------------------------------------------
# development: desarrollo local
# production: produccion
# test: pruebas automatizadas
NODE_ENV=development

# ------------------------------------------------------------
# BASE DE DATOS
# ------------------------------------------------------------
# SQLite para desarrollo local y Docker.
# La base se guarda en backend/prisma/dev.db.
# Si prefieres otra ruta, usa formato file:./ruta/a/tu.db
# Ejemplos: file:./dev.db | file:./backend/prisma/dev.db | file:/app/data/anamneo.db
DATABASE_URL="file:./dev.db"

# Base opcional para pruebas E2E.
# Si se deja vacia, los tests generan una DB temporal automaticamente.
# Ejemplo: file:./test-e2e.db
TEST_DATABASE_URL=

# ------------------------------------------------------------
# JWT / AUTENTICACION
# ------------------------------------------------------------
# Secret para firmar el access token.
# Recomendacion: usar al menos 32 bytes aleatorios.
#
# Comandos utiles para generar secretos seguros:
#   openssl rand -base64 48
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=replace-with-a-secure-random-secret

# Duracion del access token.
# Ejemplos: 15m, 30m, 1h, 12h
JWT_EXPIRES_IN=15m

# Secret para firmar el refresh token.
# Debe ser distinto del JWT_SECRET.
JWT_REFRESH_SECRET=replace-with-a-different-secure-random-secret

# Token requerido para bootstrap de la primera cuenta administradora.
# En produccion debe ser aleatorio, privado y distinto de los JWT secrets.
# Ejemplos:
#   openssl rand -base64 48
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
BOOTSTRAP_TOKEN=replace-with-a-secure-bootstrap-token

# Duracion del refresh token.
# Ejemplos: 7d, 14d, 30d
JWT_REFRESH_EXPIRES_IN=7d

# En produccion, SQLite requiere habilitacion explicita.
# Mantener en false y preferir PostgreSQL.
ALLOW_SQLITE_IN_PRODUCTION=false

# ------------------------------------------------------------
# SQLITE OPERATIVO (PRODUCCION)
# ------------------------------------------------------------
# Modo de journaling recomendado para concurrencia/recuperacion.
SQLITE_SYNCHRONOUS=NORMAL

# Tiempo de espera para evitar errores "database is locked" en picos.
SQLITE_BUSY_TIMEOUT_MS=5000

# Frecuencia de autocheckpoint de WAL (en paginas).
SQLITE_WAL_AUTOCHECKPOINT_PAGES=1000

# Directorio de backups .db.
# Si se omite, se usa <directorio_db>/backups
SQLITE_BACKUP_DIR=./backend/prisma/backups

# Politica de retencion para backups automaticos.
SQLITE_BACKUP_RETENTION_DAYS=14

# Umbral maximo de edad del ultimo backup (para monitoreo).
SQLITE_BACKUP_MAX_AGE_HOURS=24

# Umbral de alerta para crecimiento del archivo WAL.
SQLITE_WAL_WARN_SIZE_MB=128

# Cadencia objetivo (dias) para ejecutar restore drill.
SQLITE_RESTORE_DRILL_FREQUENCY_DAYS=7

# Fuerza el restore drill en la siguiente ejecucion del runner operativo.
# Util para validaciones manuales; dejar en false normalmente.
SQLITE_FORCE_RESTORE_DRILL=false

# Cron schedule para backups automaticos en Docker (default: cada 6 horas).
# Ejemplos: "0 */6 * * *" (cada 6h), "0 2 * * *" (2am diario), "*/30 * * * *" (cada 30min)
BACKUP_CRON_SCHEDULE=0 */6 * * *

# Politica de notificacion del runner operacional: on-failure|always|never
SQLITE_NOTIFY_POLICY=on-failure

# Nombre del servicio enviado en payloads de alerta.
SQLITE_ALERT_SERVICE_NAME=anamneo-backend

# Webhook HTTP para alertas operativas de SQLite (backup falló, WAL grande, etc.).
# ⚠️ IMPORTANTE para producción: configurar para recibir notificaciones de fallos.
# Ejemplos:
#   Discord: https://discord.com/api/webhooks/XXXX/YYYY
#   Slack:   https://hooks.slack.com/services/XXXX/YYYY/ZZZZ
#   Ntfy:    https://ntfy.sh/anamneo-alerts
# Dejar vacío solo en desarrollo.
SQLITE_ALERT_WEBHOOK_URL=

# ------------------------------------------------------------
# BACKEND HTTP
# ------------------------------------------------------------
# Puerto donde expone la API.
PORT=5678

# Puertos de host para Docker Compose (no cambia puertos internos).
BACKEND_PORT=5678
FRONTEND_PORT=5555

# Hosts de bind para Docker Compose en el host.
# En produccion, este proyecto esta pensado para publicarse detras de cloudflared,
# asi que el default recomendado es loopback y no 0.0.0.0.
BACKEND_BIND_HOST=127.0.0.1
FRONTEND_BIND_HOST=127.0.0.1

# Zona horaria clinica usada para comparaciones de fecha sin hora (seguimientos, edad, vencimientos).
# Default recomendado para esta app: America/Santiago
# Ejemplos: America/Santiago | UTC
APP_TIME_ZONE=America/Santiago

# Origen permitido para llamadas del frontend.
# Si cambias el puerto del frontend, actualiza este valor.
# En produccion con cloudflared, debe incluir el hostname HTTPS publico del tunnel.
# Ejemplos: http://localhost:5555 | https://anamneo.lat | https://app.anamneo.lat,https://admin.anamneo.lat
CORS_ORIGIN=http://localhost:5555,https://anamneo.cloudbox.lat

# Configuracion de proxy inverso.
# Usa 1 o una lista de proxies confiables cuando el backend corre detras de Nginx/LB.
# En Docker Compose con cloudflared u otro proxy inverso, usar 1.
TRUST_PROXY=false

# ------------------------------------------------------------
# FRONTEND
# ------------------------------------------------------------
# URL publica del frontend usada para construir enlaces en correos.
# En produccion con cloudflared, debe ser el hostname HTTPS publico del tunnel.
# Ejemplos: http://localhost:5555 | https://anamneo.lat
APP_PUBLIC_URL=http://localhost:5555

# (Opcional) URL alternativa del frontend para correos.
# Si se omite, usa APP_PUBLIC_URL.
# Ejemplos: https://app.anamneo.lat | https://staging.anamneo.lat
FRONTEND_PUBLIC_URL=

# URL de API usada por el navegador.
# En desarrollo normal y en produccion con cloudflared debe quedar en same-origin para preservar cookies HttpOnly.
# Ejemplos: /api | https://anamneo.lat/api
NEXT_PUBLIC_API_URL=/api

# Destino real del proxy server-side de Next.js.
# En desarrollo local suele apuntar directo al backend Nest.
# Ejemplos: http://localhost:5678/api | http://backend:5678/api
API_PROXY_TARGET=http://localhost:5678/api

# Origenes extra permitidos por Next.js en desarrollo.
# Dejar vacio salvo que necesites abrir la app desde otra IP/host.
# Ejemplos: 192.168.1.20,anamneo.local,dev.anamneo.test
NEXT_ALLOWED_DEV_ORIGINS=

# ------------------------------------------------------------
# CORREO SMTP (OPCIONAL)
# ------------------------------------------------------------
# Estos valores actuan como fallback del backend.
# Tambien pueden configurarse desde Ajustes > Correo SMTP.
# Si guardas secretos SMTP desde Ajustes, define esta clave para cifrarlos en reposo.
# Para rotacion, puedes definir varias claves separadas por comas y dejar la activa primero.
# Recomendacion: al menos 32 caracteres aleatorios.
SETTINGS_ENCRYPTION_KEY=replace-with-a-secure-settings-key
SETTINGS_ENCRYPTION_KEYS=

# Cifrado opcional de campos legacy a nivel aplicacion.
# Debe ser una clave hex de 64 caracteres (256 bits).
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Anamneo
INVITATION_EMAIL_SUBJECT=Invitacion a {{clinicName}}

# ------------------------------------------------------------
# ARCHIVOS / UPLOADS
# ------------------------------------------------------------
# Tamano maximo de archivo en bytes.
# 10485760 = 10 MB
UPLOAD_MAX_SIZE=10485760

# Ruta donde se guardan archivos subidos.
# El path es relativo a la raiz del repo.
UPLOAD_DEST=./uploads

# ------------------------------------------------------------
# MONITOREO / APM (OPCIONAL)
# ------------------------------------------------------------
# DSN de Sentry para tracking de errores.
# Dejar vacio para deshabilitar.
# Ejemplo: https://<key>@o123456.ingest.de.sentry.io/1234567
SENTRY_DSN=
# Ejemplo: https://<public-key>@o123456.ingest.de.sentry.io/1234567
NEXT_PUBLIC_SENTRY_DSN=
