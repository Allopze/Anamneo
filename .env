# ============================================================
# Configuracion local del proyecto
# Archivo usado por backend, frontend y comandos de Prisma.
# ============================================================

# ------------------------------------------------------------
# ENTORNO
# ------------------------------------------------------------
# development: desarrollo local
# production: produccion
# test: pruebas automatizadas
NODE_ENV=development

# ------------------------------------------------------------
# BASE DE DATOS
# ------------------------------------------------------------
# SQLite local para desarrollo.
# La ruta esta escrita pensando en el repo root.
# El backend la normaliza a una ruta absoluta al arrancar.
# Si migras a PostgreSQL, un ejemplo seria:
# DATABASE_URL="postgresql://usuario:password@localhost:5432/pacientes?schema=public"
DATABASE_URL="file:./backend/prisma/dev.db"

# ------------------------------------------------------------
# JWT / AUTENTICACION
# ------------------------------------------------------------
# Secret usado para firmar el access token.
# Debe ser largo, aleatorio y distinto entre ambientes.
#
# Formas recomendadas de generar un secret seguro:
#   openssl rand -base64 48
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
#
# No reutilices el mismo valor para JWT_SECRET y JWT_REFRESH_SECRET.
JWT_SECRET=fichas-clinicas-secret-key-dev-2024

# Tiempo de vida del access token.
# Ejemplos validos: 15m, 1h, 12h, 1d
JWT_EXPIRES_IN=15m

# Secret usado para firmar el refresh token.
# Debe ser distinto al JWT_SECRET.
JWT_REFRESH_SECRET=fichas-clinicas-refresh-secret-key-dev-2024

# Tiempo de vida del refresh token.
# Suele ser mayor que el access token.
JWT_REFRESH_EXPIRES_IN=7d

# ------------------------------------------------------------
# BACKEND HTTP
# ------------------------------------------------------------
# Puerto donde escucha la API NestJS.
PORT=4444

# Origen permitido para CORS.
# Debe coincidir con la URL desde donde carga el frontend.
CORS_ORIGIN=http://localhost:5555,http://192.168.4.96:5555

# ------------------------------------------------------------
# FRONTEND
# ------------------------------------------------------------
# URL publica de la API consumida por Next.js en navegador.
# Debe incluir el prefijo /api porque el backend lo expone ahi.
NEXT_PUBLIC_API_URL=http://192.168.4.96:4444/api

# ------------------------------------------------------------
# ARCHIVOS / UPLOADS
# ------------------------------------------------------------
# Tamano maximo de archivo en bytes.
# 10485760 = 10 MB
UPLOAD_MAX_SIZE=10485760

# Carpeta donde el backend guarda archivos subidos.
# El path es relativo a la raiz del repo.
UPLOAD_DEST=./uploads
