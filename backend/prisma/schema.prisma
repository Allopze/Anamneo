// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("MIGRATION_DATABASE_URL")
}

// Models
model User {
  id                  String   @id @default(uuid())
  email               String   @unique
  passwordHash        String   @map("password_hash")
  nombre              String
  role                String   @default("ASISTENTE")
  isAdmin             Boolean  @default(false) @map("is_admin")
  medicoId            String?  @map("medico_id")
  active              Boolean  @default(true)
  mustChangePassword  Boolean  @default(false) @map("must_change_password")
  totpSecret          String?  @map("totp_secret")
  totpEnabled         Boolean  @default(false) @map("totp_enabled")
  totpRecoveryCodes   String?  @map("totp_recovery_codes")
  refreshTokenVersion Int      @default(0) @map("refresh_token_version")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  medico     User?  @relation("MedicoAssistants", fields: [medicoId], references: [id])
  assistants User[] @relation("MedicoAssistants")

  createdPatients       Patient[]               @relation("PatientCreatedBy")
  encounters            Encounter[]
  medicoEncounters      Encounter[]             @relation("EncounterMedico")
  requestedReviewEncounters Encounter[]         @relation("EncounterReviewRequestedBy")
  reviewedEncounters    Encounter[]             @relation("EncounterReviewedBy")
  completedEncounters   Encounter[]             @relation("EncounterCompletedBy")
  attachments           Attachment[]
  deletedAttachments    Attachment[]  @relation("AttachmentDeletedBy")
  sessions              UserSession[]
  conditionCatalogLocal ConditionCatalogLocal[]
  textTemplates         TextTemplate[]
  encounterTasks        EncounterTask[]
  patientProblems       PatientProblem[]
  medicoPatientProblems PatientProblem[]  @relation("ProblemMedico")
  medicoEncounterTasks  EncounterTask[]   @relation("TaskMedico")
  grantedConsents       ClinicalConsent[] @relation("ConsentGrantedBy")
  revokedConsents       ClinicalConsent[] @relation("ConsentRevokedBy")
  capturedDataProcessingConsents PatientDataProcessingConsent[] @relation("DataProcessingConsentCapturedBy")
  resolvedDataRequests  PatientDataRequest[] @relation("DataRequestResolvedBy")
  createdDataRequestDownloads PatientDataRequestDownload[] @relation("DataRequestDownloadCreatedBy")
  createdPatientPortalAccounts PatientPortalAccount[] @relation("PatientPortalAccountCreatedBy")
  createdClinicalAlerts ClinicalAlert[]   @relation("ClinicalAlertCreatedBy")
  acknowledgedAlerts    ClinicalAlert[]   @relation("ClinicalAlertAcknowledgedBy")
  createdAllergies      PatientAllergy[]  @relation("PatientAllergyCreatedBy")
  createdMedications    PatientMedication[] @relation("PatientMedicationCreatedBy")
  medicoAppointments    Appointment[]     @relation("AppointmentMedico")
  createdAppointments   Appointment[]     @relation("AppointmentCreatedBy")
  legalAcceptances       UserLegalAcceptance[]
  passwordResetTokens    PasswordResetToken[]
  onboardingProgresses   UserOnboardingProgress[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Patient {
  id              String    @id @default(uuid())
  createdById     String    @map("created_by_id")
  rutExempt       Boolean   @default(false) @map("rut_exempt")
  rutExemptReason String?   @map("rut_exempt_reason")
  fechaNacimiento DateTime?       @map("fecha_nacimiento")
  edad            Int?
  edadMeses       Int?            @map("edad_meses")
  sexo            String?
  trabajo         String?
  prevision       String?
  registrationMode String   @default("COMPLETO") @map("registration_mode")
  completenessStatus String @default("VERIFICADA") @map("completeness_status")
  demographicsVerifiedAt DateTime? @map("demographics_verified_at")
  demographicsVerifiedById String? @map("demographics_verified_by_id")
  centroMedico    String?   @map("centro_medico")
  // Ley 21.719 Art 14 quinquies lit a (cifrado a nivel app de
  // identificatorios sensibles). Phase C: las columnas plaintext fueron
  // eliminadas; el codigo solo escribe `*_enc` y `rut_lookup_hash`.
  // El hash de lookup permite mantener UNIQUE/lookup por RUT sin descifrar.
  rutEnc                          String? @map("rut_enc")
  rutLookupHash                   String? @unique @map("rut_lookup_hash")
  nombreEnc                       String? @map("nombre_enc")
  telefonoEnc                     String? @map("telefono_enc")
  emailEnc                        String? @map("email_enc")
  domicilioEnc                    String? @map("domicilio_enc")
  contactoEmergenciaNombreEnc     String? @map("contacto_emergencia_nombre_enc")
  contactoEmergenciaTelefonoEnc   String? @map("contacto_emergencia_telefono_enc")
  archivedAt      DateTime? @map("archived_at")
  archivedById    String?   @map("archived_by_id")
  // Ley 21.719 Art 8 ter (bloqueo temporal del tratamiento)
  blockedAt       DateTime? @map("blocked_at")
  blockedReason   String?   @map("blocked_reason")
  blockedById     String?   @map("blocked_by_id")
  // Ley 21.719 Art 8 (oposicion) - JSON con flags por finalidad
  // Ej: { "ANALITICA_INTERNA": true, "COMUNICACIONES": false }
  processingObjections Json? @map("processing_objections")
  // Ley 21.719 Art 16 quater (representante legal NNA)
  legalRepresentativeNameEnc         String? @map("legal_representative_name_enc")
  legalRepresentativeRutEnc          String? @map("legal_representative_rut_enc")
  legalRepresentativeRutLookupHash   String? @map("legal_representative_rut_lookup_hash")
  legalRepresentativeRelationshipEnc String? @map("legal_representative_relationship_enc")
  legalRepresentativeContactEnc      String? @map("legal_representative_contact_enc")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  createdBy  User             @relation("PatientCreatedBy", fields: [createdById], references: [id])
  history    PatientHistory?
  encounters Encounter[]
  episodes   EncounterEpisode[]
  problems   PatientProblem[]
  tasks      EncounterTask[]
  consents   ClinicalConsent[]
  dataProcessingConsents PatientDataProcessingConsent[]
  dataRequests           PatientDataRequest[]
  dataRequestDownloads   PatientDataRequestDownload[]
  portalAccounts         PatientPortalAccount[]
  alerts     ClinicalAlert[]
  clinicalSearches PatientClinicalSearch[]
  allergies        PatientAllergy[]
  medications      PatientMedication[]
  appointments     Appointment[]
  vitalSigns        EncounterVitalSigns[]

  @@index([archivedAt])
  @@index([blockedAt])
  @@index([createdById, archivedAt, createdAt])
  @@index([completenessStatus, archivedAt])
  @@index([updatedAt])
  @@map("patients")
}

model PatientClinicalSearch {
  id        String   @id @default(uuid())
  patientId String   @map("patient_id")
  medicoId  String   @map("medico_id")
  text      String
  updatedAt DateTime @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, medicoId])
  @@index([medicoId])
  @@index([patientId])
  @@map("patient_clinical_search")
}

// Status enum: ACTIVO | SUSPENDIDO
// deletedAt enables soft-delete (medication marked inactive, not purged).
model PatientMedication {
  id          String    @id @default(uuid())
  patientId   String    @map("patient_id")
  drug        String
  dose        String?
  route       String?
  frequency   String?
  status      String    @default("ACTIVO")
  startDate   DateTime? @map("start_date")
  notes       String?
  deletedAt   DateTime? @map("deleted_at")
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdBy User    @relation("PatientMedicationCreatedBy", fields: [createdById], references: [id])

  @@index([patientId, deletedAt])
  @@map("patient_medications")
}

// Severity enum: LEVE | MODERADA | GRAVE | FATAL
// deletedAt enables soft-delete (allergy marked inactive, not purged).
model PatientAllergy {
  id            String    @id @default(uuid())
  patientId     String    @map("patient_id")
  allergen      String
  severity      String    @default("MODERADA")
  reactionType  String?   @map("reaction_type")
  onsetDate     DateTime? @map("onset_date")
  notes         String?
  deletedAt     DateTime? @map("deleted_at")
  createdById   String    @map("created_by_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdBy User    @relation("PatientAllergyCreatedBy", fields: [createdById], references: [id])

  @@index([patientId, deletedAt])
  @@map("patient_allergies")
}

model PatientHistory {
  id                            String   @id @default(uuid())
  patientId                     String   @unique @map("patient_id")
  antecedentesMedicos           String?  @map("antecedentes_medicos")
  antecedentesQuirurgicos       String?  @map("antecedentes_quirurgicos")
  antecedentesGinecoobstetricos String?  @map("antecedentes_ginecoobstetricos")
  antecedentesFamiliares        String?  @map("antecedentes_familiares")
  habitos                       String?
  medicamentos                  String?
  alergias                      String?
  inmunizaciones                String?
  antecedentesSociales          String?  @map("antecedentes_sociales")
  antecedentesPersonales        String?  @map("antecedentes_personales")
  updatedAt                     DateTime @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("patient_histories")
}

model Encounter {
  id                String    @id @default(uuid())
  patientId         String    @map("patient_id")
  medicoId          String    @map("medico_id")
  createdById       String    @map("created_by_id")
  appointmentId     String?   @unique @map("appointment_id")
  status            String    @default("EN_PROGRESO")
  reviewStatus      String    @default("NO_REQUIERE_REVISION") @map("review_status")
  reviewRequestedAt DateTime? @map("review_requested_at")
  reviewRequestedById String? @map("review_requested_by_id")
  reviewedAt        DateTime? @map("reviewed_at")
  reviewedById      String?   @map("reviewed_by_id")
  reviewNote        String?   @map("review_note")
  completedAt       DateTime? @map("completed_at")
  completedById     String?   @map("completed_by_id")
  episodeId         String?   @map("episode_id")
  closureNote       String?   @map("closure_note")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  patient     Patient                  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  medico      User                     @relation("EncounterMedico", fields: [medicoId], references: [id])
  createdBy   User                     @relation(fields: [createdById], references: [id])
  appointment Appointment?             @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  reviewRequestedBy User?              @relation("EncounterReviewRequestedBy", fields: [reviewRequestedById], references: [id])
  reviewedBy  User?                    @relation("EncounterReviewedBy", fields: [reviewedById], references: [id])
  completedBy User?                    @relation("EncounterCompletedBy", fields: [completedById], references: [id])
  episode     EncounterEpisode?        @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  sections    EncounterSection[]
  signatures  EncounterSignature[]
  consents    ClinicalConsent[]
  alerts      ClinicalAlert[]
  suggestions ConditionSuggestionLog[]
  attachments Attachment[]
  tasks       EncounterTask[]
  problems    PatientProblem[]
  diagnoses  EncounterDiagnosis[]
  treatments EncounterTreatment[]
  vitalSigns EncounterVitalSigns?

  @@index([medicoId])
  @@index([medicoId, status, createdAt])
  @@index([medicoId, reviewStatus, createdAt])
  @@index([patientId, medicoId, createdAt])
  @@index([appointmentId])
  @@index([updatedAt])
  @@map("encounters")
}

model EncounterEpisode {
  id              String   @id @default(uuid())
  patientId       String   @map("patient_id")
  label           String
  normalizedLabel String   @default("") @map("normalized_label")
  firstEncounterId String? @map("first_encounter_id")
  lastEncounterId  String? @map("last_encounter_id")
  startDate       DateTime? @map("start_date")
  endDate         DateTime? @map("end_date")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  encounters Encounter[]

  @@index([patientId])
  @@index([normalizedLabel])
  @@map("encounter_episodes")
}

model EncounterSignature {
  id            String    @id @default(uuid())
  encounterId   String    @map("encounter_id")
  userId        String    @map("user_id")
  signatureType String    @default("FES") @map("signature_type")
  contentHash   String    @map("content_hash")
  ipAddress     String?   @map("ip_address")
  userAgent     String?   @map("user_agent")
  signedAt      DateTime  @default(now()) @map("signed_at")
  revokedAt     DateTime? @map("revoked_at")
  revokedReason String?   @map("revoked_reason")

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@map("encounter_signatures")
}

model EncounterSection {
  id                 String   @id @default(uuid())
  encounterId        String   @map("encounter_id")
  sectionKey         String   @map("section_key")
  data               String
  schemaVersion      Int      @default(1) @map("schema_version")
  completed          Boolean  @default(false)
  notApplicable      Boolean  @default(false) @map("not_applicable")
  notApplicableReason String? @map("not_applicable_reason")
  updatedAt          DateTime @updatedAt @map("updated_at")

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@unique([encounterId, sectionKey])
  @@map("encounter_sections")
}

model EncounterVitalSigns {
  id                    String   @id @default(uuid())
  encounterId           String   @unique @map("encounter_id")
  patientId             String   @map("patient_id")
  measuredAt            DateTime @default(now()) @map("measured_at")
  bloodPressureSystolic Int?     @map("blood_pressure_systolic")
  bloodPressureDiastolic Int?    @map("blood_pressure_diastolic")
  heartRate             Int?     @map("heart_rate")
  respiratoryRate       Int?     @map("respiratory_rate")
  temperatureCelsius    Decimal? @map("temperature_celsius") @db.Decimal(4, 1)
  oxygenSaturation      Int?     @map("oxygen_saturation")
  weightKg              Decimal? @map("weight_kg") @db.Decimal(5, 2)
  heightCm              Decimal? @map("height_cm") @db.Decimal(5, 2)
  bmi                   Decimal? @db.Decimal(4, 1)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  patient   Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, measuredAt])
  @@map("encounter_vital_signs")
}

model EncounterDiagnosis {
  id              String    @id @default(uuid())
  encounterId     String    @map("encounter_id")
  source          String
  label           String
  normalizedLabel String    @default("") @map("normalized_label")
  code            String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  treatments EncounterTreatment[]

  @@index([encounterId])
  @@index([normalizedLabel])
  @@map("encounter_diagnoses")
}

model EncounterTreatment {
  id              String    @id @default(uuid())
  encounterId     String    @map("encounter_id")
  diagnosisId     String?   @map("diagnosis_id")
  treatmentType   String    @map("treatment_type")
  label           String
  normalizedLabel String    @default("") @map("normalized_label")
  details         String?
  dose            String?
  route           String?
  frequency       String?
  duration        String?
  indication      String?
  status          String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  diagnosis EncounterDiagnosis? @relation(fields: [diagnosisId], references: [id], onDelete: SetNull)
  outcomes EncounterTreatmentOutcome[]

  @@index([encounterId])
  @@index([diagnosisId])
  @@index([normalizedLabel])
  @@map("encounter_treatments")
}

model EncounterTreatmentOutcome {
  id                   String    @id @default(uuid())
  encounterTreatmentId String    @map("encounter_treatment_id")
  outcomeStatus        String    @map("outcome_status")
  outcomeSource        String    @map("outcome_source")
  adherenceStatus      String?   @map("adherence_status")
  adverseEventSeverity String?   @map("adverse_event_severity")
  adverseEventNotes    String?   @map("adverse_event_notes")
  notes                String?
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  encounterTreatment EncounterTreatment @relation(fields: [encounterTreatmentId], references: [id], onDelete: Cascade)

  @@index([encounterTreatmentId])
  @@map("encounter_treatment_outcomes")
}

model ConditionCatalog {
  id        String   @id @default(uuid())
  name      String
  cieCode   String?  @map("cie_code")
  normalizedName String @default("") @map("normalized_name")
  synonyms  String   @default("[]")
  tags      String   @default("[]")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  localOverrides ConditionCatalogLocal[]

  @@unique([normalizedName])
  @@index([cieCode])
  @@map("condition_catalog")
}

model ConditionCatalogLocal {
  id              String   @id @default(uuid())
  medicoId        String   @map("medico_id")
  baseConditionId String?  @map("base_condition_id")
  name            String
  synonyms        String   @default("[]")
  tags            String   @default("[]")
  active          Boolean  @default(true)
  hidden          Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  medico        User              @relation(fields: [medicoId], references: [id])
  baseCondition ConditionCatalog? @relation(fields: [baseConditionId], references: [id])

  @@unique([medicoId, baseConditionId])
  @@index([medicoId])
  @@map("condition_catalog_local")
}

model MedicationCatalog {
  id               String   @id @default(uuid())
  name             String
  normalizedName   String   @default("") @map("normalized_name")
  activeIngredient String   @map("active_ingredient")
  defaultDose      String?  @map("default_dose")
  defaultRoute     String?  @map("default_route")
  defaultFrequency String?  @map("default_frequency")
  active           Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([normalizedName])
  @@map("medication_catalog")
}

model ConditionSuggestionLog {
  id                String   @id @default(uuid())
  encounterId       String   @map("encounter_id")
  inputText         String   @map("input_text")
  persistedTextSnapshot String? @map("persisted_text_snapshot")
  topSuggestions    String   @map("top_suggestions")
  rankingVersion    String   @default("2026-04-name-synonyms-tags-v1") @map("ranking_version")
  rankingMetadata   String   @default("{}") @map("ranking_metadata")
  chosenConditionId String?  @map("chosen_condition_id")
  chosenMode        String   @map("chosen_mode")
  createdAt         DateTime @default(now()) @map("created_at")

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@map("condition_suggestion_logs")
}

model AuditLog {
  id            String   @id @default(uuid())
  entityType    String   @map("entity_type")
  entityId      String   @map("entity_id")
  userId        String   @map("user_id")
  requestId     String?  @map("request_id")
  action        String
  reason        String?
  result        String   @default("SUCCESS")
  diff          String?
  integrityHash String?  @map("integrity_hash")
  previousHash  String?  @map("previous_hash")
  chainSequence Int?     @unique @map("chain_sequence")
  timestamp     DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([requestId])
  @@index([action])
  @@index([reason])
  @@index([result])
  @@index([timestamp])
  @@map("audit_logs")
}

model AuditChainState {
  id         String   @id @default("default")
  latestHash String   @default("GENESIS") @map("latest_hash")
  sequence   Int      @default(0)
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("audit_chain_state")
}

model AuditIntegritySnapshot {
  id                String   @id @default("latest")
  valid             Boolean
  checked           Int
  total             Int
  brokenAt          String?  @map("broken_at")
  warning           String?
  verificationScope String   @map("verification_scope")
  verifiedAt        DateTime @default(now()) @map("verified_at")

  @@map("audit_integrity_snapshots")
}

model Attachment {
  id           String   @id @default(uuid())
  encounterId  String   @map("encounter_id")
  filename     String
  originalName String   @map("original_name")
  mime         String
  size         Int
  storagePath  String   @map("storage_path")
  uploadedById String   @map("uploaded_by_id")
  category     String?
  description  String?
  linkedOrderType  String?  @map("linked_order_type")
  linkedOrderId    String?  @map("linked_order_id")
  linkedOrderLabel String?  @map("linked_order_label")
  uploadedAt   DateTime  @default(now()) @map("uploaded_at")
  deletedAt    DateTime? @map("deleted_at")
  deletedById  String?   @map("deleted_by_id")
  scanStatus   String    @default("PENDING") @map("scan_status")
  scanResult   String?   @map("scan_result")
  scannedAt    DateTime? @map("scanned_at")
  // Ley 21.719 Art 14 quinquies (cifrado a nivel app). Cuando esta poblado,
  // el archivo en `storagePath` esta cifrado con AES-256-GCM y el envelope
  // contiene metadata para descifrarlo (algoritmo, IV, tag).
  // Formato: { "alg": "aes-256-gcm", "iv": "<b64>", "tag": "<b64>", "v": 1 }
  encryptionEnvelope Json? @map("encryption_envelope")

  encounter  Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  uploadedBy User      @relation(fields: [uploadedById], references: [id])
  deletedBy  User?     @relation("AttachmentDeletedBy", fields: [deletedById], references: [id])

  @@index([encounterId, linkedOrderType, linkedOrderId])
  @@index([deletedAt])
  @@index([scanStatus])
  @@map("attachments")
}

model PatientProblem {
  id          String    @id @default(uuid())
  patientId   String    @map("patient_id")
  encounterId String?   @map("encounter_id")
  createdById String?   @map("created_by_id")
  medicoId    String?   @map("medico_id")
  label       String
  status      String    @default("ACTIVO")
  notes       String?
  severity    String?
  onsetDate   DateTime? @map("onset_date")
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  patient   Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  encounter Encounter? @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  createdBy User?      @relation(fields: [createdById], references: [id])
  medico    User?      @relation("ProblemMedico", fields: [medicoId], references: [id])

  @@index([patientId, status])
  @@index([medicoId])
  @@map("patient_problems")
}

model EncounterTask {
  id          String    @id @default(uuid())
  patientId   String    @map("patient_id")
  encounterId String?   @map("encounter_id")
  createdById String    @map("created_by_id")
  medicoId    String?   @map("medico_id")
  recurrenceSourceTaskId String? @map("recurrence_source_task_id")
  title       String
  details     String?
  type        String    @default("SEGUIMIENTO")
