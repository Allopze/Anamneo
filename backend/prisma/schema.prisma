  createdBy       User       @relation("ClinicalAlertCreatedBy", fields: [createdById], references: [id])
  acknowledgedBy  User?      @relation("ClinicalAlertAcknowledgedBy", fields: [acknowledgedById], references: [id])

  @@index([patientId, acknowledgedAt])
  @@index([patientId, acknowledgedAt, createdAt])
  @@index([encounterId, acknowledgedAt])
  @@map("clinical_alerts")
}

