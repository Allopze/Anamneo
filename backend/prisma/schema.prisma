// Consentimiento clinico de un acto medico (procedimiento, tratamiento,
// investigacion). Otorgado por un User (medico/asistente) en nombre del
// paciente. Renombrado desde InformedConsent como parte del roadmap Ley
// 21.719: el consentimiento de TRATAMIENTO DE DATOS PERSONALES (Art 12)
// se modela aparte en PatientDataProcessingConsent.
model ClinicalConsent {
  id          String    @id @default(uuid())
  patientId   String    @map("patient_id")
  encounterId String?   @map("encounter_id")
  type        String    @default("TRATAMIENTO")
  description String
  grantedAt   DateTime  @default(now()) @map("granted_at")
  grantedById String    @map("granted_by_id")
  revokedAt   DateTime? @map("revoked_at")
  revokedById String?   @map("revoked_by_id")
  revokedReason String? @map("revoked_reason")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  patient   Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  encounter Encounter? @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  grantedBy User       @relation("ConsentGrantedBy", fields: [grantedById], references: [id])
  revokedBy User?      @relation("ConsentRevokedBy", fields: [revokedById], references: [id])

  @@index([patientId, revokedAt])
  @@index([patientId, revokedAt, grantedAt])
  @@map("clinical_consents")
}

// Ley 21.719 Art 12 - consentimiento del TITULAR (no del medico) para el
// tratamiento de datos personales. Vincula a la version exacta del
// LegalDocument (politica de privacidad) aceptada y captura evidencia
// probatoria (Art 12 inciso final: carga de la prueba sobre el responsable).
model PatientDataProcessingConsent {
  id              String   @id @default(uuid())
  patientId       String   @map("patient_id")
  legalDocumentId String   @map("legal_document_id")
  // ATENCION_CLINICA | ANALITICA_INTERNA | COMUNICACIONES | INVESTIGACION
  purpose         String
  granted         Boolean  @default(true)
  grantedAt       DateTime @default(now()) @map("granted_at")
  revokedAt       DateTime? @map("revoked_at")
  // PRESENCIAL_TABLET | WEB_TITULAR | REPRESENTANTE
  method          String
  capturedIp      String?  @map("captured_ip")
  capturedUserAgent String? @map("captured_user_agent")
  // El User que asistio la captura (medico/asistente). Nullable cuando el
  // titular firmo via WEB_TITULAR sin asistencia.
  capturedByUserId String? @map("captured_by_user_id")
  // Identidad declarada del firmante cifrada app-level
  signerNameEnc         String? @map("signer_name_enc")
  signerRutEnc          String? @map("signer_rut_enc")
  signerRutLookupHash   String? @map("signer_rut_lookup_hash")
  // TITULAR | PADRE | MADRE | TUTOR | REPRESENTANTE
  signerRelationship String @map("signer_relationship")
  // SHA-256 del payload firmado para integridad
  evidenceHash    String   @map("evidence_hash")
  // Campos adicionales recomendados por asesor legal
  // (ver docs/respuestas-borrador-ley21719.md §2.4):
  // - language: idioma del texto mostrado al titular
  // - sessionId: id de sesion HTTP / portal que capturo el consent
  // - clinicId: clinica/establecimiento responsable (cuando aplique
  //   multi-clinica en el futuro; hoy puede quedar NULL en single-clinic)
  // - representativeBondEvidenceRef: URL/path en drive seguro al documento
  //   que acredita el vinculo del representante con el NNA (cuando aplique)
  // - consentPayloadSnapshot: snapshot inmutable del payload exacto firmado
  //   (texto mostrado + checkboxes + version UI). El hash de este snapshot
  //   debe coincidir con evidenceHash.
  // - revokedReason: motivo de revocacion declarado por el titular
  // - revokedChannel: canal por el que se ejerce la revocacion
  //   (WEB_TITULAR | PRESENCIAL | EMAIL | DPO)
  language        String?  @default("es-CL")
  sessionId       String?  @map("session_id")
  clinicId        String?  @map("clinic_id")
  representativeBondEvidenceRef String? @map("representative_bond_evidence_ref")
  consentPayloadSnapshot Json? @map("consent_payload_snapshot")
  revokedReason   String?  @map("revoked_reason")
  revokedChannel  String?  @map("revoked_channel")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  patient        Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  legalDocument  LegalDocument @relation(fields: [legalDocumentId], references: [id])
  capturedBy     User?         @relation("DataProcessingConsentCapturedBy", fields: [capturedByUserId], references: [id])

  @@index([patientId, purpose, revokedAt])
  @@index([legalDocumentId])
  @@map("patient_data_processing_consents")
}

// Ley 21.719 Art 4-11 - solicitudes del titular para ejercer sus derechos.
// El SLA del Art 11 (30 dias corridos + prorroga 30 mas) se calcula en
// `dueDate` y `prorrogaDueDate`.
model PatientDataRequest {
  id          String   @id @default(uuid())
  patientId   String?  @map("patient_id")
  // ACCESO | RECTIFICACION | SUPRESION | OPOSICION | PORTABILIDAD | BLOQUEO
  requestType String   @map("request_type")
  // RECIBIDA | EN_REVISION | RESUELTA_ACEPTADA | RESUELTA_RECHAZADA | VENCIDA
  status      String   @default("RECIBIDA")
  // TITULAR | REPRESENTANTE | ADMIN
  submittedBy String   @map("submitted_by")
  submittedAt DateTime @default(now()) @map("submitted_at")
  // Datos del solicitante cifrados app-level
  requesterNameEnc         String? @map("requester_name_enc")
  requesterRutEnc          String? @map("requester_rut_enc")
  requesterRutLookupHash   String? @map("requester_rut_lookup_hash")
  requesterEmailEnc        String? @map("requester_email_enc")
  // PRESENCIAL | CEDULA_FOTO | CLAVE_UNICA | OTRO
  identityVerificationMethod String? @map("identity_verification_method")
  identityVerificationEvidence Json? @map("identity_verification_evidence")
  dueDate          DateTime  @map("due_date")
  prorrogaDueDate  DateTime? @map("prorroga_due_date")
  resolvedAt       DateTime? @map("resolved_at")
  resolvedById     String?   @map("resolved_by_id")
  resolutionNote   String?   @map("resolution_note")
  payloadRequest   String    @map("payload_request")
  payloadResponse  Json?     @map("payload_response")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  patient     Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)
  resolvedBy  User?    @relation("DataRequestResolvedBy", fields: [resolvedById], references: [id])
  downloads   PatientDataRequestDownload[]

  @@index([status, dueDate])
  @@index([patientId, requestType])
  @@index([requesterRutLookupHash])
  @@map("patient_data_requests")
}

// Entregas temporales de copias de ficha clinica al titular. El token plano
// nunca se persiste: solo `tokenHash` y metadatos auditables.
model PatientDataRequestDownload {
  id          String   @id @default(uuid())
  requestId   String   @map("request_id")
  patientId   String   @map("patient_id")
  tokenHash   String   @unique @map("token_hash")
  filePath    String   @map("file_path")
  fileSha256  String   @map("file_sha256")
  encryptionEnvelope Json? @map("encryption_envelope")
  expiresAt   DateTime @map("expires_at")
  downloadCount Int    @default(0) @map("download_count")
  maxDownloads Int     @default(3) @map("max_downloads")
  revokedAt   DateTime? @map("revoked_at")
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  request   PatientDataRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdBy User @relation("DataRequestDownloadCreatedBy", fields: [createdById], references: [id])

  @@index([requestId])
  @@index([patientId])
  @@index([expiresAt])
  @@map("patient_data_request_downloads")
}

