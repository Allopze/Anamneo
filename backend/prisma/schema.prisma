// Ley 21.719 Art 14 sexies - registro de vulneraciones a las medidas de
// seguridad. Anamneo siempre trata datos sensibles, por lo que la
// notificacion a titulares es obligatoria en toda brecha con riesgo
// razonable.
model DataBreachIncident {
  id               String   @id @default(uuid())
  detectedAt       DateTime @map("detected_at")
  // BAJO | MEDIO | ALTO | CRITICO
  severity         String
  // Resumen del alcance: que datos, cuantos titulares, vector
  scope            String
  affectedPatientIds Json?  @map("affected_patient_ids")
  rootCause        String?  @map("root_cause")
  containmentActions String? @map("containment_actions")
  // Decision documentada sobre "riesgo razonable" del Art 14 sexies
  riskAssessment   String?  @map("risk_assessment")
  reportedToAgencyAt   DateTime? @map("reported_to_agency_at")
  reportedToSubjectsAt DateTime? @map("reported_to_subjects_at")
  // ABIERTO | EN_EVALUACION | NOTIFICADO | CERRADO
  status           String   @default("ABIERTO")
  createdById      String   @map("created_by_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([severity, status])
  @@index([detectedAt])
  @@map("data_breach_incidents")
}

