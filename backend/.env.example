# Entorno
NODE_ENV=development
ANAMNEO_DEPLOYMENT_SCOPE=single-clinic

# Base de datos de test
TEST_DATABASE_URL=postgresql://anamneo_owner:anamneo_owner@localhost:5432/anamneo_test?schema=public
PLAYWRIGHT_DATABASE_URL=postgresql://anamneo_owner:anamneo_owner@localhost:5432/anamneo_playwright?schema=public

# Database (PostgreSQL)
DATABASE_URL=postgresql://anamneo_app:anamneo_app@localhost:5432/anamneo?schema=public&connection_limit=10&pool_timeout=10
MIGRATION_DATABASE_URL=postgresql://anamneo_owner:anamneo_owner@localhost:5432/anamneo?schema=public

# JWT
JWT_SECRET=replace-with-a-secure-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-secure-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=5678
BACKEND_PORT=5678
FRONTEND_PORT=5555
BACKEND_BIND_HOST=127.0.0.1
FRONTEND_BIND_HOST=127.0.0.1
APP_TIME_ZONE=America/Santiago
CORS_ORIGIN=http://localhost:5555,https://anamneo.cloudbox.lat
APP_PUBLIC_URL=http://localhost:5555
FRONTEND_PUBLIC_URL=
TRUST_PROXY=false

# Uploads
UPLOAD_MAX_SIZE=10485760
UPLOAD_DEST=./uploads

# PostgreSQL ops
PG_BACKUP_DIR=./backend/prisma/backups
PG_BACKUP_RETENTION_DAYS=14
PG_BACKUP_MAX_AGE_HOURS=24
PG_RESTORE_DRILL_FREQUENCY_DAYS=7
PG_FORCE_RESTORE_DRILL=false
BACKUP_CRON_SCHEDULE=0 */6 * * *
PG_NOTIFY_POLICY=on-failure
PG_ALERT_SERVICE_NAME=anamneo-backend
PG_ALERT_WEBHOOK_URL=

# SMTP and settings encryption (optional fallback for invitation emails)
SETTINGS_ENCRYPTION_KEY=replace-with-a-secure-settings-key
SETTINGS_ENCRYPTION_KEYS=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Anamneo
INVITATION_EMAIL_SUBJECT=Invitacion a {{clinicName}}

# Encryption at-rest (AES-256-GCM) — 64 hex chars (256 bits)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
ENCRYPTION_AT_REST_CONFIRMED=false

# Monitoring
SENTRY_DSN=
