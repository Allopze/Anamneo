# Database (SQLite)
DATABASE_URL=file:./dev.db

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=4444
CORS_ORIGIN=http://localhost:5555,https://anamneo.cloudbox.lat
APP_PUBLIC_URL=http://localhost:5555

# SMTP (optional fallback for invitation emails)
SETTINGS_ENCRYPTION_KEY=replace-with-a-secure-settings-key
SETTINGS_ENCRYPTION_KEYS=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Anamneo
INVITATION_EMAIL_SUBJECT=Invitacion a {{clinicName}}

# Node
NODE_ENV=development
